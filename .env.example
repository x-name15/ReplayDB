# 🕰️ ReplayDB Configuration
# The TCP port for the binary wire protocol (used by recli).
REDB_PORT=7800

# The HTTP port for the read-only monitoring dashboard.
REDB_HTTP_PORT=8080

# Directory where events.redb and snapshots.redb are stored.
REDB_DATA_DIR=data

# --- DASHBOARD AUTH (optional) ---
# HTTP Basic Auth for the dashboard at REDB_HTTP_PORT.
# Both must be set together to enable it — if either is empty, the
# dashboard runs open (fine for local dev, redb logs a warning on boot).
# Set both before exposing the dashboard beyond localhost/a trusted network.
REDB_DASHBOARD_USER=
REDB_DASHBOARD_PASS=