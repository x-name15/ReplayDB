# 🕰️ ReplayDB Configuration
# The TCP port for the binary wire protocol (used by recli).
REDB_PORT=7800

# The HTTP port for the read-only monitoring dashboard.
REDB_HTTP_PORT=8080

# Directory where events.redb and snapshots.redb are stored.
REDB_DATA_DIR=data

# --- TCP WIRE PROTOCOL AUTH (optional but strongly recommended) ---
# Shared-secret token required to talk to the TCP wire protocol at REDB_PORT.
# If unset, redb runs open (fine for local dev, redb logs a loud warning on
# boot). Set it before exposing REDB_PORT beyond localhost/a trusted network.
# recli also reads this same variable to authenticate outgoing requests.
REDB_AUTH_TOKEN=

# --- TCP WIRE PROTOCOL LIMITS ---
# Max number of simultaneous TCP wire connections. Extra connections are
# rejected immediately (with an error frame) instead of piling up.
REDB_MAX_CONNECTIONS=500

# Max size in bytes for any single field/frame read off the wire (e.g. an
# event payload). Requests exceeding this are rejected. Lower this if you
# don't need large payloads — it directly bounds per-connection memory use.
REDB_MAX_PAYLOAD_BYTES=4194304

# --- ARCHIVING (optional, non-destructive) ---
# Periodically mirrors newly appended bytes from events.redb/snapshots.redb
# into REDB_ARCHIVE_DIR. This is a backup/cold-storage aid, not compaction:
# it never truncates, rewrites, or deletes anything from the live files, so
# time-travel replay is completely unaffected. Both must be set to enable it;
# otherwise redb logs that archiving is disabled and runs as before.
# REDB_ARCHIVE_INTERVAL accepts Go duration syntax (e.g. 30m, 6h, 24h).
REDB_ARCHIVE_DIR=
REDB_ARCHIVE_INTERVAL=

# --- DASHBOARD AUTH (optional) ---
# HTTP Basic Auth for the dashboard at REDB_HTTP_PORT.
# Both must be set together to enable it — if either is empty, the
# dashboard runs open (fine for local dev, redb logs a warning on boot).
# Set both before exposing the dashboard beyond localhost/a trusted network.
REDB_DASHBOARD_USER=
REDB_DASHBOARD_PASS=